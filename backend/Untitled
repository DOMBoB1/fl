    def _update_fps(self, now: float):
        dt = now - self._last_time
        self._last_time = now
        fps_inst = (1.0 / dt) if dt > 1e-6 else 0.0
        self._fps_smooth = 0.9 * self._fps_smooth + 0.1 * fps_inst

    def _maybe_store_report(
        self,
        now: float,
        faces: int,
        heads: int,
        fatigue: int,
        attention: int,
        fatigue_alert_active: bool,
        attention_alert_active: bool,
        student_alerts: List[dict],
        class_decision_explanation: str,
    ):
        self._report_buffer.append(
            {
                "ts": now,
                "faces": float(faces),
                "heads": float(heads),
                "fatigue": float(fatigue),
                "attention": float(attention),
                "fatigue_alert_active": bool(fatigue_alert_active),
                "attention_alert_active": bool(attention_alert_active),
                "student_alert_count": int(len(student_alerts or [])),
                "critical_student_count": int(
                    sum(1 for x in (student_alerts or []) if str(x.get("severity", "")) == "critical")
                ),
                "decision_explanation": str(class_decision_explanation or ""),
            }
        )

        if not self.session_active or self.session_id is None:
            return

        interval_s = int(getattr(config, "REPORT_INTERVAL_S", 60))
        if interval_s <= 0:
            interval_s = 60

        if now - self._last_report_ts < interval_s:
            return

        if not self._report_buffer:
            self._last_report_ts = now
            return

        faces_avg = float(np.mean([x["faces"] for x in self._report_buffer]))
        heads_avg = float(np.mean([x["heads"] for x in self._report_buffer]))
        fatigue_avg = float(np.mean([x["fatigue"] for x in self._report_buffer]))
        attention_avg = float(np.mean([x["attention"] for x in self._report_buffer]))
        fatigue_max = float(np.max([x["fatigue"] for x in self._report_buffer]))
        attention_min = float(np.min([x["attention"] for x in self._report_buffer]))
        student_alert_count = int(max(x["student_alert_count"] for x in self._report_buffer))
        critical_student_count = int(max(x["critical_student_count"] for x in self._report_buffer))

        last = self._report_buffer[-1]
        class_alert_type, class_alert_level = self._class_alert_type_and_level(
            fatigue_alert_active=bool(last["fatigue_alert_active"]),
            attention_alert_active=bool(last["attention_alert_active"]),
            active_students=int(round(faces_avg)),
        )
        reason, decision = self._class_reason_and_decision(
            class_avg_fatigue=fatigue_avg,
            class_avg_attention=attention_avg,
            fatigue_alert_active=bool(last["fatigue_alert_active"]),
            attention_alert_active=bool(last["attention_alert_active"]),
            active_students=int(round(faces_avg)),
            class_decision_explanation=str(last.get("decision_explanation", "")),
        )

        insert_snapshot(
            db_path=config.DB_PATH,
            session_id=self.session_id,
            created_at=now,
            faces_avg=faces_avg,
            heads_avg=heads_avg,
            active_students_avg=faces_avg,
            fatigue_avg=fatigue_avg,
            attention_avg=attention_avg,
            fatigue_max=fatigue_max,
            attention_min=attention_min,
            class_alert_type=class_alert_type,
            class_alert_level=class_alert_level,
            student_alert_count=student_alert_count,
            critical_student_count=critical_student_count,
            reason=reason,
            decision=decision,
        )

        self._recent_reports = get_recent_snapshots(
            config.DB_PATH,
            session_id=self.session_id,
            limit=getattr(config, "RECENT_REPORTS_IN_UI", 3),
        )

        self._report_buffer = []
        self._last_report_ts = now

